        <!-- =========================================
             PAGE 6: SYSTEM DESIGN PAGE
             ========================================= -->
        <section id="page-project-design" class="portfolio-page">
            <div class="section-header">
                <span class="subtitle">Architectural Blueprint</span>
                <h2>System Design</h2>
            </div>

            <h3 style="font-size:1.6rem; color:var(--accent-orange); margin-bottom:1.5rem;">Architecture Block Map</h3>
            <div class="architecture-grid">
                <div class="arch-block-card">
                    <div class="arch-block-title">Frontend Client</div>
                    <p style="font-size:0.95rem;">React SPA, modular component state orchestration, Vite HMR, and Tailwind UI elements.</p>
                </div>
                <div class="arch-block-card">
                    <div class="arch-block-title">Backend API</div>
                    <p style="font-size:0.95rem;">REST API routing, Passport middleware controllers, and token routers.</p>
                </div>
                <div class="arch-block-card">
                    <div class="arch-block-title">Prisma Connector</div>
                    <p style="font-size:0.95rem;">Object-relational connector generating secure database queries.</p>
                </div>
                <div class="arch-block-card">
                    <div class="arch-block-title">Database Storage</div>
                    <p style="font-size:0.95rem;">MongoDB Atlas storing unstructured specs lists and inventory datasets.</p>
                </div>
            </div>

            <h3 style="font-size:1.6rem; color:var(--accent-orange); margin-bottom:1rem;">Tech Stack Decision Rationale</h3>
            <div class="glass-table-wrapper">
                <table class="glass-table">
                    <thead>
                        <tr>
                            <th>Technology Choice</th>
                            <th>Architectural Motivation & Rationale</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>React + Vite</strong></td>
                            <td>Delivers rapid Hot Module Replacement (HMR), components encapsulation, and efficient DOM renders.</td>
                        </tr>
                        <tr>
                            <td><strong>Express.js</strong></td>
                            <td>Provides a lightweight, unopinionated routing layer to construct API responses rapidly.</td>
                        </tr>
                        <tr>
                            <td><strong>MongoDB</strong></td>
                            <td>Flexible document model seamlessly maps varied specifications of diverse security equipment.</td>
                        </tr>
                        <tr>
                            <td><strong>Prisma ORM</strong></td>
                            <td>Type-safe query compilation, simple schema files, and automated database transitions.</td>
                        </tr>
                        <tr>
                            <td><strong>React Query</strong></td>
                            <td>Performs declarative background caching and avoids redundant client network fetch loops.</td>
                        </tr>
                        <tr>
                            <td><strong>Stateless JWT</strong></td>
                            <td>Enables lightweight validation headers without demanding storage access operations on the server.</td>
                        </tr>
                        <tr>
                            <td><strong>Google OAuth 2.0</strong></td>
                            <td>Provides quick sign-in capabilities, removing purchase friction for CCTV customers.</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Database Collections -->
            <div style="margin-top:4rem; margin-bottom:4rem;">
                <h3 style="font-size:1.6rem; color:var(--accent-orange); margin-bottom:1.5rem;">Database Collections & Fields</h3>
                <div class="timeline-steps">
                    <div class="neon-card">
                        <h4 style="color:var(--accent-cyan); margin-bottom:0.5rem;">📁 products</h4>
                        <p style="font-size:0.95rem;">id, name, brand, category, specs (JSON), images, price, stock, ratings</p>
                    </div>
                    <div class="neon-card">
                        <h4 style="color:var(--accent-cyan); margin-bottom:0.5rem;">📁 reviews</h4>
                        <p style="font-size:0.95rem;">productId, rating, comment, authorName, timestamp</p>
                    </div>
                    <div class="neon-card">
                        <h4 style="color:var(--accent-cyan); margin-bottom:0.5rem;">📁 users</h4>
