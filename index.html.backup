        <!-- =========================================
             PAGE 7: IMPLEMENTATION PAGE
             ========================================= -->
        <section id="page-project-implementation" class="portfolio-page">
            <div class="section-header">
                <span class="subtitle">Development Log</span>
                <h2>Implementation</h2>
            </div>

            <!-- Highlights -->
            <h3 style="font-size:1.6rem; color:var(--accent-orange); margin-bottom:1.5rem;">Development Highlights</h3>
            <div class="highlights-grid">
                <div class="neon-card">
                    <h4 style="color:var(--accent-cyan); margin-bottom:0.8rem;">📦 Optimized Filter Engine</h4>
                    <p>Designed a custom Multi-Filter engine using React's `useMemo` that evaluates 400+ security parts instantly across multiple parameters — without importing bulky external library assets.</p>
                </div>
                <div class="neon-card">
                    <h4 style="color:var(--accent-cyan); margin-bottom:0.8rem;">⚙️ Admin Portal Operations</h4>
                    <p>Engineered full CRUD logic allowing the store owner to add products, modify pricing, and alter core contact and operating hours details in real-time, instantly saving to MongoDB.</p>
                </div>
                <div class="neon-card">
                    <h4 style="color:var(--accent-cyan); margin-bottom:0.8rem;">📊 Data Migration Automation</h4>
                    <p>Wrote an asynchronous Node.js utility that parsed unstructured product sheets (400+ SKU lines) and transformed the records into structured, database-compatible JSON records.</p>
                </div>
                <div class="neon-card">
                    <h4 style="color:var(--accent-cyan); margin-bottom:0.8rem;">💬 Dynamic WhatsApp Linker</h4>
                    <p>Programmed a float button that auto-generates custom texts, linking a client's specific model parameters to the store owner's chat dashboard.</p>
                </div>
            </div>

            <!-- Code Editor Component -->
            <h3 style="font-size:1.6rem; color:var(--accent-orange); margin-bottom:0.5rem;">Featured Code Snippet</h3>
            <p>A look at the custom multi-filter solution powering the product catalog:</p>
            
            <div class="code-editor-mockup">
                <div class="editor-header-bar">
                    <div class="editor-dots">
                        <span class="editor-dot dot-red"></span>
                        <span class="editor-dot dot-yellow"></span>
                        <span class="editor-dot dot-green"></span>
                    </div>
                    <span class="editor-title">ProductFilterEngine.js</span>
                </div>
                <pre class="editor-pre-content"><code class="editor-code-body"><span class="c-cm">// Custom multi-criteria evaluation routine (optimized for 400+ SKUs)</span>
<span class="c-kw">const</span> <span class="c-vr">filteredProducts</span> = <span class="c-fn">useMemo</span>(() => {
  <span class="c-kw">return</span> <span class="c-vr">products</span>.<span class="c-fn">filter</span>(<span class="c-vr">product</span> => {
    <span class="c-kw">const</span> <span class="c-vr">matchesCategory</span> = !<span class="c-vr">filters</span>.<span class="c-vr">category</span> || <span class="c-vr">product</span>.<span class="c-vr">category</span> === <span class="c-vr">filters</span>.<span class="c-vr">category</span>;
    <span class="c-kw">const</span> <span class="c-vr">matchesBrand</span>    = !<span class="c-vr">filters</span>.<span class="c-vr">brand</span>    || <span class="c-vr">product</span>.<span class="c-vr">brand</span> === <span class="c-vr">filters</span>.<span class="c-vr">brand</span>;
    <span class="c-kw">const</span> <span class="c-vr">matchesType</span>     = !<span class="c-vr">filters</span>.<span class="c-vr">type</span>     || <span class="c-vr">product</span>.<span class="c-vr">type</span> === <span class="c-vr">filters</span>.<span class="c-vr">type</span>;
    <span class="c-kw">const</span> <span class="c-vr">matchesResolution</span> = !<span class="c-vr">filters</span>.<span class="c-vr">res</span>    || <span class="c-vr">product</span>.<span class="c-vr">resolution</span> === <span class="c-vr">filters</span>.<span class="c-vr">res</span>;
    
    <span class="c-kw">return</span> <span class="c-vr">matchesCategory</span> && <span class="c-vr">matchesBrand</span> && <span class="c-vr">matchesType</span> && <span class="c-vr">matchesResolution</span>;
  });
}, [<span class="c-vr">products</span>, <span class="c-vr">filters</span>]);</code></pre>
            </div>

            <!-- Sprint History -->
            <h3 style="font-size:1.6rem; color:var(--accent-orange); margin-bottom:1.5rem;">Sprint History</h3>
            <div class="timeline-vertical">
