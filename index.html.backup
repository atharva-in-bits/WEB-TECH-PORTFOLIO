    <!-- Back to Top Widget -->
    <button id="back-to-top" class="back-to-top-widget" aria-label="Scroll back to top">
        <svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 15l7-7 7 7" stroke-linecap="round" stroke-linejoin="round"></path></svg>
    </button>

    <!-- Core Scripts Router & Particle Canvas Background -->
    <script>
        /* =========================================
           1. CLIENT-SIDE HASH ROUTING CONTROLLER
           ========================================= */
        const projectSubpages = ['project-overview', 'project-analysis', 'project-design', 'project-implementation', 'project-testing'];

        function updateProjectSubnav(pageId) {
            document.querySelectorAll('.project-subnav a').forEach(link => {
                link.classList.toggle('active', link.getAttribute('href') === '#' + pageId);
            });
        }

        function initProjectSubnav() {
            const projectNavMarkup = `
                <nav class="project-subnav" aria-label="Project page navigation">
                    <a href="#project-overview">Overview</a>
                    <a href="#project-analysis">Analysis</a>
                    <a href="#project-design">System Design</a>
                    <a href="#project-implementation">Implementation</a>
                    <a href="#project-testing">Testing</a>
                </nav>
            `;

            projectSubpages.forEach(pageId => {
                const page = document.getElementById('page-' + pageId);
                if (page && !page.querySelector('.project-subnav')) {
                    page.insertAdjacentHTML('afterbegin', projectNavMarkup);
                }
            });
        }

        function setupHashLinks() {
            document.querySelectorAll('a[href^="#"]').forEach(link => {
                link.addEventListener('click', event => {
                    const pageId = link.getAttribute('href').substring(1);
                    const target = document.getElementById('page-' + pageId);

                    if (target) {
                        event.preventDefault();
                        window.location.hash = pageId;
                        navigateTo(pageId);
                    }
                });
            });
        }

        function navigateTo(pageId) {
            // Close mobile menu first if open
            document.getElementById('nav-menu').classList.remove('mobile-open');
            
            // Hide all views
            const pages = document.querySelectorAll('.portfolio-page');
            pages.forEach(page => {
                page.classList.remove('active');
            });

            // Show active target
            const activePage = document.getElementById('page-' + pageId);
            if (activePage) {
                activePage.classList.add('active');
            }

            // Update navbar items
            const navLinks = document.querySelectorAll('.nav-link, .dropdown-item');
            navLinks.forEach(link => {
                link.classList.remove('active');
            });

            // Mark active element
            const activeLink = document.getElementById('link-' + pageId);
            if (activeLink) {
                activeLink.classList.add('active');
            }

            // Handle Project Dropdown trigger highlighting
            const projectTrigger = document.getElementById('project-dropdown-trigger');
            if (projectSubpages.includes(pageId)) {
                projectTrigger.classList.add('active');
            } else {
                projectTrigger.classList.remove('active');
            }

            // Scroll cleanly to top
            window.scrollTo({ top: 0, behavior: 'smooth' });

            // Trigger Count-Up stats if switching to home page
            if (pageId === 'home') {
                setTimeout(initCountUp, 300);
            }

            updateProjectSubnav(pageId);
        }

        // Router listener routing dynamic window hashes
        function handleRouting() {
            const hash = window.location.hash.substring(1);
            const validPages = ['home', 'about', 'learning', 'project-overview', 'project-analysis', 'project-design', 'project-implementation', 'project-testing', 'certification', 'reflections'];
            
            if (validPages.includes(hash)) {
                navigateTo(hash);
            } else {
                navigateTo('home');
                window.location.hash = 'home';
            }
        }

        window.addEventListener('hashchange', handleRouting);
        window.addEventListener('DOMContentLoaded', () => {
            initProjectSubnav();
            setupHashLinks();
            handleRouting();
        });

        /* =========================================
           2. INTERACTIVE HEADER & MOBILE ACCENTS
           ========================================= */
        window.addEventListener('scroll', () => {
            const header = document.getElementById('main-header');
            const topBtn = document.getElementById('back-to-top');
            
            if (window.scrollY > 50) {
                header.classList.add('scrolled');
            } else {
                header.classList.remove('scrolled');
            }

            if (window.scrollY > 400) {
                topBtn.classList.add('visible');
            } else {
                topBtn.classList.remove('visible');
            }
        });

        // Mobile Hamburger Toggle
        const hamburger = document.getElementById('menu-hamburger');
        const navMenu = document.getElementById('nav-menu');

        hamburger.addEventListener('click', () => {
            navMenu.classList.toggle('mobile-open');
        });

        // Scroll back to top trigger
        document.getElementById('back-to-top').addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        /* =========================================
           INTERACTIVE DEMOS FOR LEARNING PAGE
           ========================================= */
        function runJavaScriptDemo() {
            const consoleBox = document.getElementById('js-console-output');
            consoleBox.innerHTML = '';
            
            // Add lines mimicking compiler/execution
            const lines = [
                { text: '> Initializing compiler runtime...', type: 'info' },
                { text: '> Array team loaded with 2 elements.', type: 'info' },
                { text: '> Running team.filter(member => member.role === "Lead")...', type: 'info' },
                { text: 'Match: Atharva', type: 'success' },
                { text: 'Script exited successfully with status 0.', type: 'info' }
            ];
            
            lines.forEach((line, index) => {
                setTimeout(() => {
                    const lineEl = document.createElement('div');
                    lineEl.className = 'console-line ' + (line.type === 'success' ? 'console-line-success' : line.type === 'info' ? 'console-line-info' : '');
                    lineEl.innerText = line.text;
                    consoleBox.appendChild(lineEl);
                }, index * 400);
            });
        }
        
        let reactCounterStateVal = 0;
        function incrementReactCounter() {
            reactCounterStateVal++;
            document.getElementById('react-counter-val').innerText = reactCounterStateVal;
        }
        function decrementReactCounter() {
            reactCounterStateVal--;
            document.getElementById('react-counter-val').innerText = reactCounterStateVal;
        }

        /* =========================================
           3. INTERACTIVE ACCORDIONS (LEARNINGS)
           ========================================= */
        function togglePanel(panelId) {
            const panel = document.getElementById('panel-' + panelId);
            const activeStatus = panel.classList.contains('active');
            
            // Collapse all panels first
            const allPanels = document.querySelectorAll('.expandable-panel');
            allPanels.forEach(p => p.classList.remove('active'));
            
            // Expand clicked panel if it wasn't open
            if (!activeStatus) {
                panel.classList.add('active');
            }
        }

        /* =========================================
           4. VISUAL STATISTICS COUNT-UP EFFECT
           ========================================= */
        let countUpExecuted = false;
        function initCountUp() {
            if (countUpExecuted) return;
            const stats = document.querySelectorAll('.stat-number-label[data-target]');
            
            stats.forEach(stat => {
                const target = parseInt(stat.getAttribute('data-target'), 10);
                const isPlus = stat.innerText.includes('+');
                let count = 0;
                const increment = Math.ceil(target / 50);
                const timer = setInterval(() => {
                    count += increment;
                    if (count >= target) {
                        count = target;
                        clearInterval(timer);
                    }
                    stat.innerText = count + (isPlus ? '+' : '');
                }, 30);
            });
            countUpExecuted = true;
        }

        /* =========================================
           5. INTERACTIVE SCHEMATIC CANVAS BACKGROUND
           ========================================= */
        const canvas = document.getElementById('circuit-canvas');
        const ctx = canvas.getContext('2d');

        let width = canvas.width = window.innerWidth;
        let height = canvas.height = window.innerHeight;

        window.addEventListener('resize', () => {
            width = canvas.width = window.innerWidth;
            height = canvas.height = window.innerHeight;
        });

        class Node {
            constructor(x, y) {
                this.x = x;
                this.y = y;
                this.baseX = x;
                this.baseY = y;
                this.radius = Math.random() * 2 + 1.5;
                this.pulse = Math.random() * Math.PI;
                this.speed = 0.02;
            }

            draw() {
                this.pulse += this.speed;
                const alpha = 0.15 + Math.sin(this.pulse) * 0.08;
                
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.radius + Math.sin(this.pulse) * 0.8, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(0, 212, 255, ${alpha})`;
                ctx.shadowBlur = 10;
                ctx.shadowColor = 'rgba(0, 212, 255, 0.4)';
                ctx.fill();
                ctx.shadowBlur = 0; // Reset blur
            }

            update() {
                // Subtle organic floating movement
                this.x = this.baseX + Math.sin(this.pulse) * 4;
                this.y = this.baseY + Math.cos(this.pulse) * 4;
            }
        }

        const nodesList = [];
        const maxNodes = 65;

        // Generate grid-like nodes mirroring circuit points
        for (let i = 0; i < maxNodes; i++) {
            nodesList.push(new Node(
                Math.random() * width,
                Math.random() * height
            ));
        }

        function drawConnections() {
            ctx.strokeStyle = 'rgba(0, 212, 255, 0.035)';
            ctx.lineWidth = 1;
            
            for (let i = 0; i < nodesList.length; i++) {
                for (let j = i + 1; j < nodesList.length; j++) {
                    const dist = Math.hypot(nodesList[i].x - nodesList[j].x, nodesList[i].y - nodesList[j].y);
                    
                    if (dist < 180) {
                        ctx.beginPath();
                        ctx.moveTo(nodesList[i].x, nodesList[i].y);
                        
                        // Trace orthogonal line segments resembling PCB wires
                        const midX = (nodesList[i].x + nodesList[j].x) / 2;
                        ctx.lineTo(midX, nodesList[i].y);
                        ctx.lineTo(midX, nodesList[j].y);
                        ctx.lineTo(nodesList[j].x, nodesList[j].y);
                        ctx.stroke();
                    }
                }
            }
        }

        function animateBgCanvas() {
            ctx.clearRect(0, 0, width, height);
            
            drawConnections();
            
            nodesList.forEach(node => {
                node.update();
                node.draw();
            });
            
            requestAnimationFrame(animateBgCanvas);
        }

        animateBgCanvas();

        /* =========================================
           6. INTERACTIVE SCREENSHOT LIGHTBOX
           ========================================= */
        window.openLightbox = function(element) {
            const lightbox = document.getElementById('image-lightbox');
            const img = document.getElementById('lightbox-img');
            const caption = document.getElementById('lightbox-caption');
            
            const cardImg = element.querySelector('.screenshot-img');
            const cardTitle = element.querySelector('.screenshot-info h5').innerText;
            const cardDesc = element.querySelector('.screenshot-info p').innerText;

            img.src = cardImg.src;
            caption.innerHTML = `<span style="color:var(--accent-cyan); font-weight:700;">${cardTitle}</span> &middot; <span style="color:var(--text-secondary); font-size:1rem;">${cardDesc}</span>`;
            
            lightbox.classList.add('active');
            document.body.style.overflow = 'hidden'; // Disable background scrolling
        }

        window.closeLightbox = function() {
            const lightbox = document.getElementById('image-lightbox');
            lightbox.classList.remove('active');
            document.body.style.overflow = 'auto'; // Re-enable scrolling
        }
    </script>

    <!-- Lightbox Modal -->
    <div id="image-lightbox" class="lightbox-modal" onclick="closeLightbox()">
        <span class="lightbox-close" onclick="closeLightbox()">&times;</span>
        <img class="lightbox-content" id="lightbox-img" alt="Enlarged screenshot view">
        <div id="lightbox-caption" class="lightbox-caption"></div>
    </div>
</body>
</html>





