                                <pre class="editor-pre-content"><code class="editor-code-body"><span class="c-kw">import</span> { <span class="c-vr">useState</span> } <span class="c-kw">from</span> <span class="c-st">'react'</span>;

<span class="c-kw">export default function</span> <span class="c-fn">Counter</span>() {
  <span class="c-kw">const</span> [<span class="c-vr">count</span>, <span class="c-vr">setCount</span>] = <span class="c-fn">useState</span>(<span class="c-st">0</span>);

  <span class="c-kw">return</span> (
    <span class="c-kw">&lt;div&gt;</span>
      <span class="c-kw">&lt;h3&gt;</span>Value: {<span class="c-vr">count</span>}<span class="c-kw">&lt;/h3&gt;</span>
      <span class="c-kw">&lt;button</span> <span class="c-vr">onClick</span>={<span class="c-vr">() =&gt; setCount</span>(<span class="c-vr">c =&gt; c + 1</span>)}<span class="c-kw">&gt;</span>+<span class="c-kw">&lt;/button&gt;</span>
    <span class="c-kw">&lt;/div&gt;</span>
  );
}</code></pre>
                            </div>
