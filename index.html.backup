                                    <span class="editor-title">FilterEngine.js</span>
                                </div>
                                <pre class="editor-pre-content"><code class="editor-code-body"><span class="c-kw">const</span> <span class="c-vr">team</span> = [
  { <span class="c-vr">name</span>: <span class="c-st">'Atharva'</span>, <span class="c-vr">role</span>: <span class="c-st">'Lead'</span> },
  { <span class="c-vr">name</span>: <span class="c-st">'Atharva'</span>, <span class="c-vr">role</span>: <span class="c-st">'Sys'</span> }
];

<span class="c-cm">// Evaluates role parameter array</span>
<span class="c-kw">const</span> <span class="c-vr">leads</span> = <span class="c-vr">team</span>.<span class="c-fn">filter</span>(
  <span class="c-vr">member</span> =&gt; <span class="c-vr">member</span>.<span class="c-vr">role</span> === <span class="c-st">'Lead'</span>
);

<span class="c-vr">console</span>.<span class="c-fn">log</span>(<span class="c-st">'Match:'</span>, <span class="c-vr">leads</span>[<span class="c-st">0</span>].<span class="c-vr">name</span>);</code></pre>
                            </div>
